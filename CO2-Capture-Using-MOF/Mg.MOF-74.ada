SystemData : Text
globaldatasection
EndText;
SystemData : Text
<FORMLIST DEFAULTFORM="AllGlobals">
  <FORM NAME="AllGlobals" CLSID="{6BA76840-806B-11D0-BE51-0000C09984EF}">
    { Version : 1
SizeX : 5250
SizeY : 3750
ShowAllVariables : True
ShowAllAttributes : False
ExpandAll : True
ShowRegistryAttributes : True
VariablesPaths : [ ]
AttributesPaths : [ ]
ColumnWidths : [ ]
}
  </FORM>
</FORMLIST>
EndText;

FLOWSHEET
  BED as gas_bed;
  VFCO2 as gas_valve;
  PROD as gas_product;
  FEED1 as gas_feed;
  FEED2 as gas_feed;
  MEZCLA as gas_tank_void;
  VFN2 as gas_valve;
  VP as gas_valve;
  TopTank as gas_tank_void;
  Cycle_Organizer as Cycle_Organizer;
  S1 as gas_Material_Connection;
  S5 as gas_Material_Connection;
  S6 as gas_Material_Connection;
  S7 as gas_Material_Connection;
  S8 as gas_Material_Connection;
  S11 as gas_Material_Connection;
  S12 as gas_Material_Connection;
  S4 as gas_Material_Connection;
  Connect FEED1.Process_Out and VFCO2.Process_In with S1;
  Connect VFCO2.Process_Out and MEZCLA.Process_In with S5;
  Connect FEED2.Process_Out and VFN2.Process_In with S6;
  Connect VFN2.Process_Out and MEZCLA.Process_In with S7;
  Connect MEZCLA.Process_Out and BED.Process_In with S8;
  Connect BED.Process_Out and TopTank.Process_In with S11;
  Connect TopTank.Process_Out and VP.Process_In with S12;
  Connect VP.Process_Out and PROD.Process_In with S4;

CONSTRAINTS
  // Flowsheet variables and equations...
END

Task Cycle1 Runs Always

// DO NOT RENAME THIS TASK OR CYCLE ORGANIZER CANNOT DIRECTLY CONTROL IT!
// ALL MANUAL EDITS WILL BE LOST WHEN THIS TASK IS REGENERATED OR IF CYCLES ARE DELETED!

// Define and initialize local parameters
  Cycle_Start        As IntegerParameter;
  Cycle_Count        As IntegerParameter;
  String_Cycle_Count As StringParameter;
  String_Max_Cycles  As StringParameter;
  Step_End_Time      As RealParameter;
  Rec_Ini            As IntegerParameter;
  Rec_Freq           As IntegerParameter;
  DoRecord           As LogicalParameter;
  IsCyclicSS         As LogicalParameter;
  NowTime            As RealParameter;

// Does this cycle need to go into standby
  If Cycle_Organizer.Cycle_Data(1).PauseCycle > 0.5 Then
    Print(0) " ";
    Print(0) "Cycle 1 will go into standby";
    Wait For Cycle_Organizer.Cycle_Data(1).PauseCycle < 0.5;
    Print(0) " ";
    Print(0) "Cycle 1 is now active";
  EndIf

// Reseting of cycle and restart counts
  If Cycle_Count > 0 And (TIME < Step_End_Time Or TIME <= 1e-5) Then
    Cycle_Count : 0;
  EndIf

// Preset step times of known time driven steps
  If Cycle_Count == 0 Then
    If Cycle_Organizer.IsReporting == TRUE
       And Cycle_Organizer.Cycle_Data(1).ControlsReporting == TRUE Then
      Invoke ADSIM.ReportRecordScript;
      If Cycle_Organizer.Cycle_Data(1).RecordFrequency <> 1 Then
        Rec_Ini  : Cycle_Organizer.Cycle_Data(1).RecordInitial;
        Rec_Freq : Cycle_Organizer.Cycle_Data(1).RecordFrequency;
        Invoke ADSIM.SaveRecordScript;
      EndIf
    EndIf
    Cycle_Organizer.Cycle_Data(1).Step_Time(1) : Cycle_Organizer.Cycle_Data(1).Step_Data(1).StepTimeUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(1).StepTime + Cycle_Organizer.Cycle_Data(1).Step_Data(1).StepTimeUOMOffset;
    Cycle_Organizer.Cycle_Data(1).Step_Time(2) : Cycle_Organizer.Cycle_Data(1).Step_Data(2).StepTimeUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(2).StepTime + Cycle_Organizer.Cycle_Data(1).Step_Data(2).StepTimeUOMOffset;
    Cycle_Organizer.Cycle_Data(1).Step_Time(3) : Cycle_Organizer.Cycle_Data(1).Step_Data(3).StepTimeUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(3).StepTime + Cycle_Organizer.Cycle_Data(1).Step_Data(3).StepTimeUOMOffset;
    Cycle_Organizer.Cycle_Data(1).Step_Time(4) : Cycle_Organizer.Cycle_Data(1).Step_Data(4).StepTimeUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(4).StepTime + Cycle_Organizer.Cycle_Data(1).Step_Data(4).StepTimeUOMOffset;
    Cycle_Organizer.Cycle_Data(1).Step_Time(5) : Cycle_Organizer.Cycle_Data(1).Step_Data(5).StepTimeUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(5).StepTime + Cycle_Organizer.Cycle_Data(1).Step_Data(5).StepTimeUOMOffset;
  EndIf

// Snapshot control
  // Take snapshot labeled Cycle1_CycleSnap at end of cycle (if required)
  If Cycle_Count > 0 And Cycle_Organizer.Cycle_Data(1).TakeSnapshots == TRUE
     And ((DoRecord == TRUE And Cycle_Organizer.Cycle_Data(1).RecordFrequency <> 1)
          Or Cycle_Organizer.Cycle_Data(1).RecordFrequency == 1) Then
    Create Snapshot "Cycle1_CycleSnap";
  EndIf
  // Take snapshot labeled Cycle1_Step5Snapshot at end of step 5 (if required)
  If Cycle_Count > 0 And Cycle_Organizer.Cycle_Data(1).Step_Data(5).TakeSnapshots == TRUE
     And Not Cycle_Organizer.Cycle_Data(1).TakeSnapshots == TRUE
     And ((DoRecord == TRUE And Cycle_Organizer.Cycle_Data(1).RecordFrequency <> 1)
          Or Cycle_Organizer.Cycle_Data(1).RecordFrequency == 1) Then
    Create Snapshot "Cycle1_Step5Snap";
  EndIf

// Preset previous cycle count at first start of task
  If Cycle_Count == 0 Then
    Cycle_Start : 0;
  EndIf

// Call script to record previous step and cycles times
  If (Cycle_Count == 0 Or DoRecord == TRUE)
     And Cycle_Organizer.IsReporting == TRUE
     And Cycle_Organizer.Cycle_Data(1).ControlsReporting == TRUE Then
    Invoke ADSIM.UpdateCycleTimesScript(Cycle_Count,TIME,"Cycle_Organizer");
  EndIf

// Cyclic convergence testing
  If Cycle_Organizer.Cycle_Data(1).ConvTest
     And Cycle_Organizer.Cycle_Data(1).ControlsReporting == TRUE Then
    Invoke (IsCyclicSS):ADSIM.CycConvScript(Cycle_Count);
    If Cycle_Count > 0 And IsCyclicSS == TRUE
       And DoRecord == FALSE And Cycle_Organizer.Cycle_Data(1).RecordFrequency <> 1 Then
      Print(0) " ";
      Print(0) "Cyclic steady state has been acheived.";
      Print(0) "The simulation will be automatically paused at the next recorded cycle.";
      Print(0) " ";
    ElseIf Cycle_Count > 0 And IsCyclicSS == TRUE
           And ((DoRecord == TRUE And Cycle_Organizer.Cycle_Data(1).RecordFrequency <> 1)
                Or Cycle_Organizer.Cycle_Data(1).RecordFrequency == 1) Then
      Print(0) " ";
      Print(0) "Cyclic steady state has been acheived and the simulation has been automatically paused.";
      Print(0) "Press the run button to execute further cycles.";
      Print(0) " ";
      Pause;
    EndIf
  EndIf

// Do we need to pause the simulation
  If Cycle_Count == Cycle_Start + Cycle_Organizer.Cycle_Data(1).MaxCycles
     And (Cycle_Organizer.Cycle_Data(1).ControlsReporting == TRUE
          Or Cycle_Organizer.Cycle_Data(1).LastCycle <> 0) Then
    String_Max_Cycles : ConvertTo(String,Cycle_Organizer.Cycle_Data(1).MaxCycles);
    Print(0) " ";
    Print(0) "The batch of " + String_Max_Cycles + " cycles has been executed.";
    Print(0) "and the simulation has been automatically paused.";
    Print(0) "Press the run button to execute a further " + String_Max_Cycles + " cycles.";
    Print(0) " ";
    Pause;
    Cycle_Start : Cycle_Start + Cycle_Organizer.Cycle_Data(1).MaxCycles;
  EndIf

// Increment the cycle counter and set cycle information
  Cycle_Count : Cycle_Count + 1;
  Cycle_Organizer.Cycle_Data(1).Current_Cycle : Cycle_Count;
  If Cycle_Organizer.IsReporting == TRUE
     And Cycle_Organizer.Cycle_Data(1).ControlsReporting == TRUE
     And Cycle_Organizer.Cycle_Data(1).RecordFrequency <> 1 Then
    Invoke (DoRecord):ADSIM.ToggleRecordScript(Cycle_Count,Rec_Ini,Rec_Freq);
  EndIf
  String_Cycle_Count : ConvertTo(String,Cycle_Count);
  Print(0) " ";
  Print(0) Cycle_Organizer.Cycle_Data(1).CycleDescription + " (Cycle 1) is starting cycle " + String_Cycle_Count;
  Cycle_Organizer.Cycle_Data(1).Cycle_Start_Time : TIME;

// Cycle 1\Step 1 manipulations
  Print(0) " ";
  Print(0) "Cycle 1\Step 1 - "+ Cycle_Organizer.Cycle_Data(1).Step_Data(1).StepDescription;
  // Preset cycle/stage information
  Cycle_Organizer.Cycle_Data(1).Current_Step : 1;
  If TIME < Cycle_Organizer.Cycle_Data(1).Step_Time(1) Then
    Cycle_Organizer.Cycle_Data(1).Cycle_Start_Time : 0;
    Cycle_Organizer.Cycle_Data(1).Step_Start_Time : 0;
  Else
    Cycle_Organizer.Cycle_Data(1).Step_Start_Time : TIME;
  EndIf
    Cycle_Organizer.Cycle_Data(1).Step_Time(1) : Cycle_Organizer.Cycle_Data(1).Step_Data(1).StepTimeUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(1).StepTime + Cycle_Organizer.Cycle_Data(1).Step_Data(1).StepTimeUOMOffset;
  Step_End_Time : Cycle_Organizer.Cycle_Data(1).Step_Start_Time + Cycle_Organizer.Cycle_Data(1).Step_Time(1);
  Cycle_Organizer.Cycle_Data(1).Current_Step_Time : Cycle_Organizer.Cycle_Data(1).Step_Time(1);

  // Manipulated variables
  FEED2.P : Cycle_Organizer.Cycle_Data(1).Step_Data(1).Manipulated(1).VarUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(1).Manipulated(1).VarValue + Cycle_Organizer.Cycle_Data(1).Step_Data(1).Manipulated(1).VarUOMOffSet;
  VFCO2.Active_Specification : Cycle_Organizer.Cycle_Data(1).Step_Data(1).Manipulated(2).VarUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(1).Manipulated(2).VarValue + Cycle_Organizer.Cycle_Data(1).Step_Data(1).Manipulated(2).VarUOMOffSet;
  VFN2.Active_Specification : Cycle_Organizer.Cycle_Data(1).Step_Data(1).Manipulated(3).VarUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(1).Manipulated(3).VarValue + Cycle_Organizer.Cycle_Data(1).Step_Data(1).Manipulated(3).VarUOMOffSet;
  VFN2.Flowrate : Cycle_Organizer.Cycle_Data(1).Step_Data(1).Manipulated(4).VarUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(1).Manipulated(4).VarValue + Cycle_Organizer.Cycle_Data(1).Step_Data(1).Manipulated(4).VarUOMOffSet;
  VP.Active_Specification : Cycle_Organizer.Cycle_Data(1).Step_Data(1).Manipulated(5).VarUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(1).Manipulated(5).VarValue + Cycle_Organizer.Cycle_Data(1).Step_Data(1).Manipulated(5).VarUOMOffSet;

  // Step wait condition
  Wait For TIME == Step_End_Time;

// Step 1 snapshot control
  // Take a snapshot labeled Cycle1_Step1Snapshot at end of step (if required)
  If Cycle_Count > 0 And Cycle_Organizer.Cycle_Data(1).Step_Data(1).TakeSnapshots == TRUE
     And ((DoRecord == TRUE And Cycle_Organizer.Cycle_Data(1).RecordFrequency <> 1)
          Or Cycle_Organizer.Cycle_Data(1).RecordFrequency == 1) Then
    Create Snapshot "Cycle1_Step1Snap";
  EndIf

// Cycle 1\Step 2 manipulations
  Print(0) " ";
  Print(0) "Cycle 1\Step 2 - "+ Cycle_Organizer.Cycle_Data(1).Step_Data(2).StepDescription;
  // Preset cycle/stage information
  Cycle_Organizer.Cycle_Data(1).Current_Step : 2;
  Cycle_Organizer.Cycle_Data(1).Step_Start_Time : TIME;
    Cycle_Organizer.Cycle_Data(1).Step_Time(2) : Cycle_Organizer.Cycle_Data(1).Step_Data(2).StepTimeUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(2).StepTime + Cycle_Organizer.Cycle_Data(1).Step_Data(2).StepTimeUOMOffset;
  Step_End_Time : Cycle_Organizer.Cycle_Data(1).Step_Start_Time + Cycle_Organizer.Cycle_Data(1).Step_Time(2);
  Cycle_Organizer.Cycle_Data(1).Current_Step_Time : Cycle_Organizer.Cycle_Data(1).Step_Time(2);

  // Manipulated variables
  FEED2.P : Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(1).VarUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(1).VarValue + Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(1).VarUOMOffSet;
  PROD.P : Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(2).VarUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(2).VarValue + Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(2).VarUOMOffSet;
  VFCO2.Active_Specification : Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(3).VarUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(3).VarValue + Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(3).VarUOMOffSet;
  VFCO2.Flowrate : Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(4).VarUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(4).VarValue + Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(4).VarUOMOffSet;
  VFN2.Active_Specification : Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(5).VarUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(5).VarValue + Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(5).VarUOMOffSet;
  VFN2.Flowrate : Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(6).VarUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(6).VarValue + Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(6).VarUOMOffSet;
  VP.Active_Specification : Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(7).VarUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(7).VarValue + Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(7).VarUOMOffSet;
  VP.Cv : Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(8).VarUOMMult * Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(8).VarValue + Cycle_Organizer.Cycle_Data(1).Step_Data(2).Manipulated(8).VarUOMOffSet;

  // Step wait condition
  Wait For TIME == Step_End_Time;

// Step 2 snapshot control
  // Take a snapshot labeled Cycle1_Step2Snapshot at end of step (if required)
  If Cycle_Count > 0 And Cycle_Organizer.Cycle_Data(1).Step_Data(2).TakeSnapshots == TRUE
     And ((DoRecord == TRUE And Cycle_Organizer.Cycle_Data(1).RecordFrequency <> 1)
          Or Cycle_Organizer.Cycle_Data(1).RecordFrequency == 1) Then
    Create Snapshot "Cycle1_Step2Snap";
  EndIf

// Cycle 1\Step 3 manipulations
  Print(0) " ";
